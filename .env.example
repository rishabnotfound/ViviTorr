# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=

# Discord Application Client ID
CLIENT_ID=

# Guild ID for faster command deployment (optional - for testing)
# Leave empty for global commands
GUILD_ID=

# TMDB API Key (from themoviedb.org)
TMDB_API_KEY=

# Redis URL (optional - for caching)
REDIS_URL=redis://localhost:6379