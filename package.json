{
  "name": "vivitorr",
  "version": "1.0.0",
  "description": "ViviTorr is a simple Discord bot that helps you search torrents quickly. Just type a command and it shows size, seeders, and the magnet link.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "deploy": "tsx src/deploy.ts"
  },
  "dependencies": {
    "discord.js": "^14.14.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rishabnotfound/ViviTorr.git"
  },
  "keywords": ["torrent", "discord bot", "discord", "scrape"],
  "author": "rishabnotfound",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/rishabnotfound/ViviTorr/issues"
  },
  "homepage": "https://github.com/rishabnotfound/ViviTorr#readme"
}
